+// CHT non-talkie TTS dub. The original v3 game has no speech; we synthesise a key
+// from the *Chinese (GBK) characters only* of the just-displayed line (ASCII /
+// control / punctuation ignored so it's identical to the build_voice dub key), and
+// play game-dir voice/<key>.voc on the talk channel with kTalkSoundID so the engine's
+// existing "hold text while talk sound runs" logic (actorTalk) syncs the subtitle.
+void Sound::playChtVoice(const byte *buf, int actor) {
+	if (!buf || !*buf)
+		return;
+	uint32 h = 2166136261u; // FNV-1a, GBK double-byte chars only
+	int n = 0;
+	for (const byte *p = buf; *p; ) {
+		if (p[0] >= 0x81 && p[0] <= 0xFE && p[1]) {
+			h = (h ^ p[0]) * 16777619u;
+			h = (h ^ p[1]) * 16777619u;
+			p += 2; n++;
+		} else {
+			p++;
+		}
+	}
+	if (n == 0)
+		return; // no CJK -> nothing dubbed
+	// speaker-map build aid: `scummvm -d3` dumps "<talking actor> <key>" for every
+	// dubbed line, so tools/ can learn which character says which key (per-character voices).
+	debug(3, "CHTMAP %d %08x", actor, (unsigned)h);
+	// English-voice (F-toggle): voice_en/ holds the en-US dub; else voice/ (Chinese).
+	const char *sub = _vm->_chtVoiceEn ? "voice_en" : "voice";
+	// voice lookup order:
+	//   1. voice[_en]/a<actor>/<key>.voc   — per-character override (e.g. Elsa female voice)
+	//   2. voice[_en]/npc/<key>.voc         — shared steadier voice for any non-ego (NPC) line
+	//                                          (1940s characters speak more calmly than Indy)
+	//   3. voice[_en]/<key>.voc             — Indy / shared default
+	int ego = (_vm->VAR_EGO != 0xFF) ? _vm->VAR(_vm->VAR_EGO) : -1;
+	bool isNpc = (actor != ego && actor > 0 && actor < 0x80);
+	ScummFile f(_vm);
+	Common::String name = Common::String::format("%s/a%d/%08x.voc", sub, actor, (unsigned)h);
+	if (!_vm->openFile(f, Common::Path(name))) {
+		bool opened = false;
+		if (isNpc) {
+			name = Common::String::format("%s/npc/%08x.voc", sub, (unsigned)h);
+			opened = _vm->openFile(f, Common::Path(name));
+		}
+		if (!opened) {
+			name = Common::String::format("%s/%08x.voc", sub, (unsigned)h);
+			if (!_vm->openFile(f, Common::Path(name)))
+				return;
+		}
+	}
+	uint32 sz = (uint32)f.size();
+	if (!sz || sz > 8 * 1024 * 1024)
+		return;
+	byte *data = (byte *)malloc(sz);
+	if (!data)
+		return;
+	f.read(data, sz);
+	Common::MemoryReadStream *ms = new Common::MemoryReadStream(data, sz, DisposeAfterUse::YES);
+	Audio::SeekableAudioStream *voc = Audio::makeVOCStream(ms, Audio::FLAG_UNSIGNED, DisposeAfterUse::YES);
+	if (!voc)
+		return;
+	_mixer->stopID(kTalkSoundID);
+	_mixer->playStream(Audio::Mixer::kSpeechSoundType, _talkChannelHandle, voc, kTalkSoundID);
+}
